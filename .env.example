# Chain-of-Trust environment config
# Copy to .env and fill in values

# Ledger mode: "mock" or "polygon"
LEDGER_MODE=mock

# Mock ledger server URL (used when LEDGER_MODE=mock)
MOCK_LEDGER_URL=http://localhost:5001

# Polygon Amoy (used when LEDGER_MODE=polygon)
ALCHEMY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY_HERE
CONTRACT_ADDRESS=

# Flask
FLASK_SECRET_KEY=change-me
FLASK_PORT=5000
